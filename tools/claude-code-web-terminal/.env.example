# Copy to .env and edit for your machine.

# Directory where the browser terminal should start.
PROJECT_DIR=E:\code\learn_p\xiaozhi-esp32-server

# Local ttyd bind address and port.
LOCAL_HOST=127.0.0.1
LOCAL_PORT=18792

# Shell to start. Use cmd.exe for best Windows compatibility.
SHELL_CMD=cmd.exe

# Optional: auto-start Claude Code instead of plain shell.
# This can be less stable on some Windows PTY setups.
# SHELL_CMD=cmd.exe /k claude

# Optional public Tailscale Funnel port.
FUNNEL_PORT=18790
