# Feedback Backend 本机环境变量示例
# 复制为 .env 或在 PowerShell 中设置后再启动 docker compose。

# 生产/测试均不要把真实密钥提交到仓库。
FEEDBACK_LLM_PROVIDER=deepseek
FEEDBACK_LLM_API_KEY=
FEEDBACK_LLM_BASE_URL=https://api.deepseek.com/v1
FEEDBACK_LLM_MODEL=deepseek-chat

# 可选：覆盖默认管理员与 JWT 密钥。
FEEDBACK_AUTH_SECRET=change-me
FEEDBACK_ADMIN_USER=admin
FEEDBACK_ADMIN_PASSWORD=admin123
